{
  "buildCommand": "cd packages/web-dashboard && yarn build",
  "outputDirectory": "packages/web-dashboard/.next",
  "installCommand": "cd packages/web-dashboard && yarn install",
  "devCommand": "cd packages/web-dashboard && yarn dev",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
